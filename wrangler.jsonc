{
  // account_id via env var: CLOUDFLARE_ACCOUNT_ID
  "name": "delzo-tools",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/_worker.js",
  "assets": {
    "directory": "dist",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "tools.delzo.cloud", "custom_domain": true }
  ]
}
