---
import ToolLayout from '../components/ToolLayout.astro';
---

<ToolLayout
  title="DNS Propagation Checker"
  description="Verificá la propagación DNS de un dominio consultando 4 resolvers públicos en paralelo."
  heading="DNS Propagation Checker"
  subheading="Consultá un dominio contra 4 resolvers DNS públicos para verificar propagación."
>
  <div slot="form">
    <div class="form-row">
      <div class="input-group">
        <label for="domain-input">Dominio</label>
        <input
          type="text"
          id="domain-input"
          placeholder="ejemplo.com"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <div class="input-group type-group">
        <label for="type-select">Tipo</label>
        <select id="type-select">
          <option value="A">A</option>
          <option value="AAAA">AAAA</option>
          <option value="MX">MX</option>
          <option value="TXT">TXT</option>
          <option value="CNAME">CNAME</option>
          <option value="NS">NS</option>
        </select>
      </div>
      <button class="btn" id="check-btn">Consultar</button>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div> Consultando resolvers...</div>
    <div class="error-msg" id="error"></div>
  </div>

  <div slot="results">
    <div class="summary-card card" id="summary-card" style="display:none;">
      <div class="summary-header" id="summary-header"></div>
      <div class="summary-answers" id="summary-answers"></div>
    </div>
    <div class="results-card card" id="results-card" style="display:none;">
      <table class="results-table">
        <thead>
          <tr>
            <th>Resolver</th>
            <th>Respuesta</th>
            <th>Tiempo</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody id="results-body"></tbody>
      </table>
    </div>
  </div>
</ToolLayout>

<style>
  .form-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .input-group {
    flex: 1;
  }

  .type-group {
    flex: 0 0 120px;
  }

  .results-card {
    overflow: hidden;
  }

  .summary-card {
    margin-bottom: 1rem;
  }

  .summary-header {
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--borde);
  }

  .summary-header.consistent {
    color: #059669;
  }

  .summary-header.inconsistent {
    color: #d97706;
  }

  .summary-answers {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  :global(.answer-group) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  :global(.answer-value) {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    background: var(--fondo-alt);
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    word-break: break-all;
    line-height: 1.5;
  }

  :global(.answer-resolvers) {
    font-size: 0.78rem;
    color: var(--gris-medio);
    padding-left: 0.2rem;
  }


  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
      align-items: stretch;
    }

    .type-group {
      flex: auto;
    }

    .form-row .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const domainInput = document.getElementById('domain-input') as HTMLInputElement;
  const typeSelect = document.getElementById('type-select') as HTMLSelectElement;
  const btn = document.getElementById('check-btn')!;
  const loading = document.getElementById('loading')!;
  const error = document.getElementById('error')!;
  const summaryCard = document.getElementById('summary-card')!;
  const summaryHeader = document.getElementById('summary-header')!;
  const summaryAnswers = document.getElementById('summary-answers')!;
  const card = document.getElementById('results-card')!;
  const tbody = document.getElementById('results-body')!;

  async function check() {
    const domain = domainInput.value.trim();
    const type = typeSelect.value;

    error.classList.remove('active');
    card.style.display = 'none';
    summaryCard.style.display = 'none';
    loading.classList.add('active');

    if (!domain) {
      loading.classList.remove('active');
      error.textContent = 'Ingresá un dominio.';
      error.classList.add('active');
      return;
    }

    try {
      const res = await fetch(`/api/dns-propagation?domain=${encodeURIComponent(domain)}&type=${type}`);
      const data = await res.json();

      loading.classList.remove('active');

      if (data.error) {
        error.textContent = data.error;
        error.classList.add('active');
        return;
      }

      // Build summary: group resolvers by their answer set
      const okResolvers = data.resolvers.filter((r: any) => r.status === 'ok');
      const answerGroups: Map<string, string[]> = new Map();

      for (const r of okResolvers) {
        const key = r.answers.length > 0 ? r.answers.join(', ') : '(sin respuesta)';
        if (!answerGroups.has(key)) answerGroups.set(key, []);
        answerGroups.get(key)!.push(r.name);
      }

      const allMatch = answerGroups.size <= 1 && okResolvers.length > 0;

      summaryHeader.className = `summary-header ${allMatch ? 'consistent' : 'inconsistent'}`;
      summaryHeader.textContent = allMatch
        ? `${okResolvers.length}/${data.resolvers.length} resolvers coinciden`
        : `Los resolvers devuelven respuestas diferentes`;

      let groupsHtml = '';
      for (const [answer, resolvers] of answerGroups) {
        groupsHtml += `
          <div class="answer-group">
            <div class="answer-value">${esc(answer)}</div>
            <div class="answer-resolvers">${resolvers.join(', ')}</div>
          </div>
        `;
      }

      const errResolvers = data.resolvers.filter((r: any) => r.status !== 'ok');
      if (errResolvers.length > 0) {
        const errNames = errResolvers.map((r: any) => r.name).join(', ');
        groupsHtml += `
          <div class="answer-group">
            <div class="answer-value" style="color:var(--gris-medio);">(error o timeout)</div>
            <div class="answer-resolvers">${esc(errNames)}</div>
          </div>
        `;
      }

      summaryAnswers.innerHTML = groupsHtml;
      summaryCard.style.display = 'block';

      // Table
      tbody.innerHTML = data.resolvers.map((r: any) => {
        const answers = r.answers.length > 0 ? r.answers.map((a: string) => '<code>' + esc(a) + '</code>').join('<br>') : '—';
        let badge = '';
        if (r.status === 'ok') badge = '<span class="badge badge-pass">✓ OK</span>';
        else if (r.status === 'timeout') badge = '<span class="badge badge-warning">⚠ Timeout</span>';
        else badge = '<span class="badge badge-fail">✗ Error</span>';

        return `<tr>
          <td><strong>${esc(r.name)}</strong></td>
          <td>${answers}</td>
          <td>${r.responseTime}ms</td>
          <td>${badge}</td>
        </tr>`;
      }).join('');

      card.style.display = 'block';
    } catch {
      loading.classList.remove('active');
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.classList.add('active');
    }
  }

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  btn.addEventListener('click', check);
  domainInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') check();
  });
</script>
