---
import ToolLayout from '../components/ToolLayout.astro';
---

<ToolLayout
  title="MX Routing Analyzer"
  description="Analizá los registros MX de un dominio: prioridades, proveedor, redundancia e IPs."
  heading="MX Routing Analyzer"
  subheading="Analizá los servidores MX de un dominio, detectá el proveedor y evaluá la redundancia."
>
  <div slot="form">
    <div class="form-row">
      <div class="input-group">
        <label for="domain-input">Dominio</label>
        <input
          type="text"
          id="domain-input"
          placeholder="ejemplo.com"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <button class="btn" id="check-btn">Analizar</button>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div> Analizando MX...</div>
    <div class="error-msg" id="error"></div>
  </div>

  <div slot="results">
    <div id="analysis-card" class="card" style="display:none;">
      <div class="analysis-grid" id="analysis-grid"></div>
    </div>
    <div class="results-card card" id="results-card" style="display:none;">
      <table class="results-table">
        <thead>
          <tr>
            <th>Prioridad</th>
            <th>Hostname</th>
            <th>IPs</th>
            <th>Proveedor</th>
          </tr>
        </thead>
        <tbody id="results-body"></tbody>
      </table>
    </div>
  </div>
</ToolLayout>

<style>
  .form-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .input-group {
    flex: 1;
  }

  .results-card {
    overflow: hidden;
  }

  .analysis-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1.25rem;
  }

  .analysis-item {
    text-align: center;
  }

  .analysis-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--gris-medio);
    margin-bottom: 0.25rem;
  }

  .analysis-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gris-oscuro);
  }

  .analysis-detail {
    grid-column: 1 / -1;
    padding-top: 0.75rem;
    border-top: 1px solid var(--borde);
    font-size: 0.88rem;
    color: var(--gris-medio);
    text-align: center;
  }

  .badge-provider {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    background: rgba(99, 102, 241, 0.1);
    color: #4f46e5;
  }

  .provider-logo {
    width: 16px;
    height: 16px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .analysis-provider {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .analysis-provider .provider-logo {
    width: 24px;
    height: 24px;
  }

  .redundancy-yes {
    color: #059669;
  }

  .redundancy-no {
    color: #d97706;
  }

  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
      align-items: stretch;
    }

    .form-row .btn {
      width: 100%;
      justify-content: center;
    }

    .analysis-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .analysis-item {
      text-align: left;
    }

    .analysis-label {
      font-size: 0.72rem;
    }

    .analysis-value {
      font-size: 0.95rem;
    }

    .analysis-detail {
      text-align: left;
    }

    .results-card {
      padding: 0 1rem;
    }

    .results-table :global(thead) {
      display: none;
    }

    .results-table :global(tr) {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem 1rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--borde);
    }

    .results-table :global(tr:last-child) {
      border-bottom: none;
    }

    .results-table :global(td) {
      border: none;
      padding: 0;
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    .results-table :global(td::before) {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--gris-claro);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .results-table :global(td:nth-child(1)::before) { content: "Prioridad: "; }
    .results-table :global(td:nth-child(2)::before) { content: "Host: "; }
    .results-table :global(td:nth-child(3)::before) { content: "IPs: "; }
    .results-table :global(td:nth-child(4)::before) { content: ""; }

    .results-table :global(td:nth-child(2)) {
      flex-basis: 100%;
    }
  }
</style>

<script>
  const domainInput = document.getElementById('domain-input') as HTMLInputElement;
  const btn = document.getElementById('check-btn')!;
  const loading = document.getElementById('loading')!;
  const error = document.getElementById('error')!;
  const analysisCard = document.getElementById('analysis-card')!;
  const analysisGrid = document.getElementById('analysis-grid')!;
  const card = document.getElementById('results-card')!;
  const tbody = document.getElementById('results-body')!;

  const PROVIDER_DOMAINS: Record<string, string> = {
    'Google Workspace': 'google.com',
    'Microsoft 365': 'microsoft.com',
    'Cloudflare': 'cloudflare.com',
    'Zoho Mail': 'zoho.com',
    'Proofpoint': 'proofpoint.com',
    'Mimecast': 'mimecast.com',
    'Barracuda': 'barracudanetworks.com',
    'GoDaddy': 'godaddy.com',
  };

  function providerLogo(name: string): string {
    const domain = PROVIDER_DOMAINS[name];
    if (!domain) return '';
    return `<img src="https://www.google.com/s2/favicons?domain=${domain}&sz=32" class="provider-logo" alt="${name}">`;
  }

  async function check() {
    const domain = domainInput.value.trim();

    error.classList.remove('active');
    card.style.display = 'none';
    analysisCard.style.display = 'none';
    loading.classList.add('active');

    if (!domain) {
      loading.classList.remove('active');
      error.textContent = 'Ingresá un dominio.';
      error.classList.add('active');
      return;
    }

    try {
      const res = await fetch(`/api/mx-analyzer?domain=${encodeURIComponent(domain)}`);
      const data = await res.json();

      loading.classList.remove('active');

      if (data.error) {
        error.textContent = data.error;
        error.classList.add('active');
        return;
      }

      const a = data.analysis;
      const redundancyClass = a.hasRedundancy ? 'redundancy-yes' : 'redundancy-no';
      const redundancyText = a.hasRedundancy ? 'Sí' : 'No';

      analysisGrid.innerHTML = `
        <div class="analysis-item">
          <div class="analysis-label">Proveedor</div>
          <div class="analysis-value"><span class="analysis-provider">${providerLogo(a.provider)}${esc(a.provider)}</span></div>
        </div>
        <div class="analysis-item">
          <div class="analysis-label">Servidores MX</div>
          <div class="analysis-value">${a.totalMx}</div>
        </div>
        <div class="analysis-item">
          <div class="analysis-label">Redundancia</div>
          <div class="analysis-value ${redundancyClass}">${redundancyText}</div>
        </div>
        <div class="analysis-detail">${esc(a.details)}</div>
      `;
      analysisCard.style.display = 'block';

      tbody.innerHTML = data.mxRecords.map((r: any) => `
        <tr>
          <td><strong>${r.priority}</strong></td>
          <td><code>${esc(r.hostname)}</code></td>
          <td>${r.ips.length > 0 ? r.ips.map((ip: string) => '<code>' + esc(ip) + '</code>').join('<br>') : '—'}</td>
          <td><span class="badge-provider">${providerLogo(r.provider)}${esc(r.provider)}</span></td>
        </tr>
      `).join('');

      card.style.display = 'block';
    } catch {
      loading.classList.remove('active');
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.classList.add('active');
    }
  }

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  btn.addEventListener('click', check);
  domainInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') check();
  });
</script>
