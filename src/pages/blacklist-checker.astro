---
import ToolLayout from '../components/ToolLayout.astro';
---

<ToolLayout
  title="Blacklist Checker"
  description="Verificá si IPs o dominios están en listas negras (DNSBL). Consultá múltiples IPs y 12 blacklists en paralelo."
  heading="Blacklist Checker"
  subheading="Verificá si IPs o dominios están listados en las principales DNSBLs."
>
  <div slot="form">
    <div class="form-row">
      <div class="input-group">
        <label for="target-input">IPs o Dominios (uno por línea)</label>
        <textarea
          id="target-input"
          placeholder="192.168.1.1&#10;ejemplo.com&#10;8.8.8.8"
          rows="4"
          spellcheck="false"
        ></textarea>
      </div>
    </div>
    <div class="form-actions">
      <button class="btn" id="check-btn">Verificar</button>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div> Consultando blacklists...</div>
    <div class="error-msg" id="error"></div>
  </div>

  <div slot="results">
    <div id="results-container"></div>
  </div>
</ToolLayout>

<style>
  .form-row {
    margin-bottom: 0.75rem;
  }

  .form-row textarea {
    width: 100%;
    min-height: 100px;
    resize: vertical;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .form-actions {
    margin-bottom: 0.75rem;
  }

  .input-group {
    flex: 1;
  }

  .input-group label {
    margin-bottom: 0.5rem;
  }

  .results-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .results-card {
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .results-card:last-child {
    margin-bottom: 0;
  }

  .results-summary {
    padding: 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-bottom: 1px solid var(--borde);
  }

  .results-summary.listed {
    background: rgba(239, 68, 68, 0.05);
    color: #dc2626;
  }

  .results-summary.clean {
    background: rgba(16, 185, 129, 0.05);
    color: #059669;
  }

  .badge-pass {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    background: rgba(16, 185, 129, 0.1);
    color: #059669;
  }

  .badge-fail {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    background: rgba(239, 68, 68, 0.1);
    color: #dc2626;
  }

  .multi-results {
    margin-top: 1rem;
  }

  .multi-results h3 {
    font-size: 1rem;
    margin: 1rem 0 0.5rem 0;
    color: var(--gris-medio);
  }

  .multi-results h3:first-child {
    margin-top: 0;
  }

  @media (max-width: 600px) {
    .form-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const targetInput = document.getElementById('target-input') as HTMLTextAreaElement;
  const btn = document.getElementById('check-btn')!;
  const loading = document.getElementById('loading')!;
  const error = document.getElementById('error')!;
  const resultsContainer = document.getElementById('results-container')!;

  async function check() {
    const targets = targetInput.value
      .split('\n')
      .map(t => t.trim())
      .filter(t => t.length > 0);

    error.classList.remove('active');
    resultsContainer.innerHTML = '';
    loading.classList.add('active');

    if (targets.length === 0) {
      loading.classList.remove('active');
      error.textContent = 'Ingresá al menos una IP o dominio.';
      error.classList.add('active');
      return;
    }

    try {
      const res = await fetch(`/api/blacklist-checker?targets=${encodeURIComponent(targets.join(','))}`);
      const data = await res.json();

      loading.classList.remove('active');

      if (data.error) {
        error.textContent = data.error;
        error.classList.add('active');
        return;
      }

      // Handle single or multiple results
      const results = Array.isArray(data) ? data : [data];

      if (results.length === 1) {
        // Single result - show in one card
        resultsContainer.appendChild(createResultCard(results[0]));
      } else {
        // Multiple results - show summary + individual cards
        const totalListed = results.filter((r: any) => r.listed > 0).length;
        const totalClean = results.length - totalListed;

        const summaryCard = document.createElement('div');
        summaryCard.className = 'results-card card';
        summaryCard.innerHTML = `
          <div class="results-summary ${totalListed > 0 ? 'listed' : 'clean'}">
            ${results.length} IPs verificadas — ${totalListed} listadas, ${totalClean} limpias
          </div>
        `;
        resultsContainer.appendChild(summaryCard);

        // Add individual results
        results.forEach((result: any) => {
          resultsContainer.appendChild(createResultCard(result));
        });
      }
    } catch {
      loading.classList.remove('active');
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.classList.add('active');
    }
  }

  function createResultCard(data: any): HTMLElement {
    const card = document.createElement('div');
    card.className = 'results-card card';

    const ipInfo = data.domain ? `${data.domain} (${data.ip})` : data.ip;
    const summaryClass = data.listed > 0 ? 'listed' : 'clean';
    const summaryText = data.listed > 0 
      ? `${ipInfo} — Listado en ${data.listed}/${data.total} blacklists`
      : `${ipInfo} — Limpio en ${data.total}/${data.total} blacklists`;

    card.innerHTML = `
      <div class="results-summary ${summaryClass}">${summaryText}</div>
      <table class="results-table">
        <thead>
          <tr>
            <th>Lista</th>
            <th>Estado</th>
            <th>Respuesta</th>
          </tr>
        </thead>
        <tbody>
          ${data.results.map((r: any) => `
            <tr>
              <td><code>${esc(r.list)}</code></td>
              <td>${r.listed ? '<span class="badge-fail">Listado</span>' : '<span class="badge-pass">Limpio</span>'}</td>
              <td>${r.response ? '<code>' + esc(r.response) + '</code>' : '—'}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;

    return card;
  }

  function esc(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  btn.addEventListener('click', check);
  targetInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.metaKey) check();
  });
</script>
