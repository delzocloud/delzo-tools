---
import ToolLayout from '../components/ToolLayout.astro';
---

<ToolLayout
  title="Certificate Transparency Monitor"
  description="Consultá certificados SSL/TLS emitidos para cualquier dominio via Certificate Transparency logs."
  heading="Certificate Transparency Monitor"
  subheading="Consultá los certificados SSL/TLS emitidos para un dominio via crt.sh."
>
  <div slot="form">
    <div class="form-row">
      <div class="input-group">
        <label for="domain-input">Dominio</label>
        <input
          type="text"
          id="domain-input"
          placeholder="ejemplo.com"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <button class="btn" id="search-btn">Buscar</button>
    </div>
    <div class="form-options">
      <label class="checkbox-label">
        <input type="checkbox" id="include-expired" />
        Incluir expirados
      </label>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div> Consultando Certificate Transparency logs...</div>
    <div class="error-msg" id="error"></div>
  </div>

  <div slot="results" id="results-container" style="display:none;">
    <div class="results-summary" id="results-summary"></div>
    <div class="certs-table-wrap card" id="certs-table-wrap" style="display:none;">
      <table class="results-table">
        <thead>
          <tr>
            <th>Common Name</th>
            <th>Estado</th>
            <th>Emisor</th>
            <th>Válido desde</th>
            <th>Vence</th>
          </tr>
        </thead>
        <tbody id="certs-body"></tbody>
      </table>
    </div>
  </div>
</ToolLayout>

<style>
  .form-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .input-group {
    flex: 1;
  }

  .form-options {
    margin-top: 0.75rem;
  }

  .checkbox-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--gris-medio);
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    accent-color: var(--verde);
    width: 16px;
    height: 16px;
  }

  .results-summary {
    font-size: 0.9rem;
    color: var(--gris-medio);
    margin-bottom: 1rem;
    padding: 0.6rem 1rem;
    background: var(--fondo-alt);
    border-radius: 10px;
  }

  .certs-table-wrap {
    overflow: hidden;
    padding: 0;
  }

  :global(.cert-cn) {
    font-weight: 600;
    word-break: break-all;
  }

  :global(.cert-sans) {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--gris-medio);
    line-height: 1.5;
    word-break: break-all;
    margin-top: 0.25rem;
  }

  :global(.cert-link) {
    font-size: 0.8rem;
    color: var(--verde);
    text-decoration: none;
  }

  :global(.cert-link:hover) {
    color: var(--verde-dark);
    text-decoration: underline;
  }

  :global(.cert-detail-row td) {
    padding-top: 0 !important;
    font-size: 0.85rem;
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
      align-items: stretch;
    }

    .form-row .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .certs-table-wrap {
      padding: 0.5rem;
    }

    .certs-table-wrap :global(.results-table thead) {
      display: none;
    }

    .certs-table-wrap :global(.results-table tr) {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.85rem 0.5rem;
      border-bottom: 1px solid var(--borde);
    }

    .certs-table-wrap :global(.results-table tr:last-child) {
      border-bottom: none;
    }

    .certs-table-wrap :global(.results-table td) {
      border: none;
      padding: 0;
    }

    .certs-table-wrap :global(.results-table tr.cert-detail-row) {
      padding-top: 0;
      margin-top: -0.5rem;
    }

    .certs-table-wrap :global(.results-table td:first-child) {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .certs-table-wrap :global(.results-table td.td-status) {
      display: none;
    }

    :global(.badge-mobile) {
      display: inline-flex !important;
    }

    .certs-table-wrap :global(.results-table td::before) {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--gris-claro);
      text-transform: uppercase;
      letter-spacing: 0.03em;
      margin-right: 0.35rem;
    }

    .certs-table-wrap :global(.results-table td:nth-child(3)::before) { content: "Emisor: "; }
    .certs-table-wrap :global(.results-table td:nth-child(4)::before) { content: "Desde: "; }
    .certs-table-wrap :global(.results-table td:nth-child(5)::before) { content: "Vence: "; }
  }

  @media (min-width: 769px) {
    :global(.badge-mobile) {
      display: none !important;
    }
  }
</style>

<script>
  const domainInput = document.getElementById('domain-input') as HTMLInputElement;
  const btn = document.getElementById('search-btn')!;
  const expiredCheckbox = document.getElementById('include-expired') as HTMLInputElement;
  const loading = document.getElementById('loading')!;
  const error = document.getElementById('error')!;
  const container = document.getElementById('results-container')!;

  function formatDate(iso: string): string {
    return new Date(iso).toLocaleDateString('es-AR', {
      year: 'numeric', month: 'short', day: 'numeric'
    });
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function extractIssuerCN(issuer: string): string {
    const match = issuer.match(/CN=([^,]+)/);
    return match ? match[1] : issuer;
  }

  async function search() {
    const domain = domainInput.value.trim();
    const includeExpired = expiredCheckbox.checked;

    error.classList.remove('active');
    container.style.display = 'none';
    loading.classList.add('active');

    if (!domain) {
      loading.classList.remove('active');
      error.textContent = 'Ingresá un dominio.';
      error.classList.add('active');
      return;
    }

    try {
      const res = await fetch(`/api/cert-monitor?domain=${encodeURIComponent(domain)}&expired=${includeExpired}`);
      const data = await res.json();

      loading.classList.remove('active');

      if (data.error) {
        error.textContent = data.error;
        error.classList.add('active');
        return;
      }

      // Summary
      document.getElementById('results-summary')!.textContent =
        `${data.total} certificado${data.total !== 1 ? 's' : ''} encontrado${data.total !== 1 ? 's' : ''} para ${data.domain}`;

      // Certs table
      const tableWrap = document.getElementById('certs-table-wrap')!;
      const tbody = document.getElementById('certs-body')!;
      tbody.innerHTML = '';

      if (data.certs.length === 0) {
        tableWrap.style.display = 'none';
        container.style.display = 'block';
        return;
      }

      const statusLabels: Record<string, string> = {
        valid: '✓ Válido',
        expiring: '⚠ Vence pronto',
        expired: '✗ Expirado',
      };
      const statusBadge: Record<string, string> = {
        valid: 'pass',
        expiring: 'warning',
        expired: 'fail',
      };

      for (const cert of data.certs) {
        const sansHtml = cert.sans.length > 0
          ? `<div class="cert-sans">${cert.sans.map((s: string) => escapeHtml(s)).join(', ')}</div>`
          : '';

        tbody.innerHTML += `
          <tr>
            <td>
              <span class="cert-cn">${escapeHtml(cert.commonName)}</span>
              <span class="badge badge-${statusBadge[cert.status]} badge-mobile">${statusLabels[cert.status]}</span>
            </td>
            <td class="td-status"><span class="badge badge-${statusBadge[cert.status]}">${statusLabels[cert.status]}</span></td>
            <td>${escapeHtml(extractIssuerCN(cert.issuer))}</td>
            <td>${formatDate(cert.notBefore)}</td>
            <td>${formatDate(cert.notAfter)}</td>
          </tr>
          <tr class="cert-detail-row">
            <td colspan="5">
              ${sansHtml}
              <a class="cert-link" href="https://crt.sh/?id=${cert.id}" target="_blank" rel="noopener">Ver en crt.sh →</a>
            </td>
          </tr>
        `;
      }

      tableWrap.style.display = 'block';
      container.style.display = 'block';
    } catch {
      loading.classList.remove('active');
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.classList.add('active');
    }
  }

  btn.addEventListener('click', search);
  domainInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') search();
  });
</script>
