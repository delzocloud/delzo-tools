---
import ToolLayout from '../components/ToolLayout.astro';
---

<ToolLayout
  title="HTTP Headers"
  description="Obtené todos los headers HTTP de respuesta de cualquier URL. Analizá seguridad, CORS, caching y más."
  heading="HTTP Headers"
  subheading="Obtené y analizá todos los headers de respuesta de cualquier sitio web."
>
  <div slot="form">
    <div class="form-row">
      <div class="input-group">
        <label for="url-input">URL o dominio</label>
        <input
          type="text"
          id="url-input"
          placeholder="ejemplo.com"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
      <button class="btn" id="check-btn">Consultar</button>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div> Obteniendo headers...</div>
    <div class="error-msg" id="error"></div>
  </div>

  <div slot="results" id="results-container" style="display:none;">
    <div class="summary-bar card">
      <div class="summary-left">
        <div class="status-badge" id="status-badge">
          <span class="status-code" id="status-code"></span>
          <span class="status-text" id="status-text"></span>
        </div>
        <div class="timing-badge">
          <span id="response-time"></span>
        </div>
      </div>
      <div class="summary-right">
        <div class="url-display" id="final-url"></div>
      </div>
    </div>

    <div class="category-summary card">
      <div class="category-stats" id="category-stats"></div>
    </div>

    <div class="headers-list" id="headers-list"></div>
  </div>
</ToolLayout>

<style>
  .form-row {
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .input-group {
    flex: 1;
  }

  .summary-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .summary-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
  }

  .status-ok .status-code {
    background: #D1FAE5;
    color: #065F46;
  }

  .status-redirect .status-code {
    background: #FEF3C7;
    color: #92400E;
  }

  .status-error .status-code {
    background: #FEE2E2;
    color: #991B1B;
  }

  .status-text {
    font-size: 0.9rem;
    color: var(--gris-oscuro);
    font-weight: 500;
  }

  .timing-badge {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--gris-medio);
  }

  .summary-right {
    flex: 1;
    min-width: 0;
  }

  .url-display {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--gris-medio);
    text-align: right;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category-summary {
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .category-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .category-pill {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    background: var(--fondo-alt);
    color: var(--gris-oscuro);
  }

  .category-pill.security {
    background: #D1FAE5;
    color: #065F46;
  }

  .category-pill.cors {
    background: #DBEAFE;
    color: #1E40AF;
  }

  .category-pill.caching {
    background: #FEF3C7;
    color: #92400E;
  }

  .category-pill.server {
    background: #E0E7FF;
    color: #3730A3;
  }

  .category-pill.content {
    background: #F3E8FF;
    color: #6B21A8;
  }

  .category-pill.other {
    background: #F3F4F6;
    color: #4B5563;
  }

  .category-count {
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .headers-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .header-card {
    background: var(--fondo-alt);
    border: 1px solid var(--borde);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
  }

  .header-card.security {
    border-left: 3px solid #10B981;
  }

  .header-card.cors {
    border-left: 3px solid #3B82F6;
  }

  .header-card.caching {
    border-left: 3px solid #F59E0B;
  }

  .header-card.server {
    border-left: 3px solid #6366F1;
  }

  .header-card.content {
    border-left: 3px solid #A855F7;
  }

  .header-card.other {
    border-left: 3px solid #9CA3AF;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .header-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--gris-oscuro);
  }

  .header-category {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .header-category.security { background: #D1FAE5; color: #065F46; }
  .header-category.cors { background: #DBEAFE; color: #1E40AF; }
  .header-category.caching { background: #FEF3C7; color: #92400E; }
  .header-category.server { background: #E0E7FF; color: #3730A3; }
  .header-category.content { background: #F3E8FF; color: #6B21A8; }
  .header-category.other { background: #F3F4F6; color: #4B5563; }

  .header-value {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: white;
    padding: 0.6rem 0.75rem;
    border-radius: 5px;
    border: 1px solid var(--borde);
    color: var(--gris-oscuro);
    word-break: break-all;
    line-height: 1.5;
    margin-top: 0.5rem;
  }

  .header-description {
    font-size: 0.8rem;
    color: var(--gris-medio);
    margin-top: 0.4rem;
  }

  @media (max-width: 600px) {
    .form-row {
      flex-direction: column;
      align-items: stretch;
    }

    .form-row .btn {
      width: 100%;
      justify-content: center;
    }

    .summary-bar {
      flex-direction: column;
      align-items: flex-start;
    }

    .url-display {
      text-align: left;
    }

    .category-stats {
      justify-content: center;
    }

    .header-row {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>

<script>
  const urlInput = document.getElementById('url-input') as HTMLInputElement;
  const btn = document.getElementById('check-btn')!;
  const loading = document.getElementById('loading')!;
  const error = document.getElementById('error')!;
  const container = document.getElementById('results-container')!;

  const categoryLabels: Record<string, string> = {
    security: 'Seguridad',
    cors: 'CORS',
    caching: 'Caching',
    server: 'Servidor',
    content: 'Contenido',
    other: 'Otros',
  };

  async function check() {
    const url = urlInput.value.trim();

    error.classList.remove('active');
    container.style.display = 'none';
    loading.classList.add('active');

    if (!url) {
      loading.classList.remove('active');
      error.textContent = 'Ingresá una URL o dominio.';
      error.classList.add('active');
      return;
    }

    try {
      const res = await fetch(`/api/http-headers?url=${encodeURIComponent(url)}`);
      const data = await res.json();

      loading.classList.remove('active');

      if (data.error) {
        error.textContent = data.error;
        error.classList.add('active');
        return;
      }

      // Status bar
      const statusBadge = document.getElementById('status-badge')!;
      statusBadge.className = `status-badge ${data.status >= 200 && data.status < 300 ? 'status-ok' : data.status >= 300 && data.status < 400 ? 'status-redirect' : 'status-error'}`;
      document.getElementById('status-code')!.textContent = String(data.status);
      document.getElementById('status-text')!.textContent = data.statusText;
      document.getElementById('response-time')!.textContent = `${data.timing}ms`;
      document.getElementById('final-url')!.textContent = data.finalUrl !== data.url ? `→ ${data.finalUrl}` : data.url;

      // Category pills
      const categoryStats = document.getElementById('category-stats')!;
      categoryStats.innerHTML = '';
      
      const categories = ['security', 'cors', 'caching', 'server', 'content', 'other'] as const;
      for (const cat of categories) {
        const count = data.summary[cat];
        if (count > 0) {
          categoryStats.innerHTML += `
            <div class="category-pill ${cat}">
              <span>${categoryLabels[cat]}</span>
              <span class="category-count">${count}</span>
            </div>
          `;
        }
      }

      // Headers list
      const headersList = document.getElementById('headers-list')!;
      headersList.innerHTML = '';

      for (const header of data.headers) {
        headersList.innerHTML += `
          <div class="header-card ${header.category}">
            <div class="header-row">
              <span class="header-name">${escapeHtml(header.name)}</span>
              <span class="header-category ${header.category}">${categoryLabels[header.category]}</span>
            </div>
            <div class="header-value">${escapeHtml(header.value)}</div>
            ${header.description ? `<div class="header-description">${escapeHtml(header.description)}</div>` : ''}
          </div>
        `;
      }

      container.style.display = 'block';
    } catch {
      loading.classList.remove('active');
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.classList.add('active');
    }
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  btn.addEventListener('click', check);
  urlInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') check();
  });
</script>
