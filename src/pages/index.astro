---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = [
  {
    title: 'DNS Lookup',
    description: 'Consultá registros DNS de cualquier dominio: A, AAAA, MX, TXT, CNAME, NS, SOA, PTR, SRV.',
    href: '/dns-lookup',
    icon: '🔍',
  },
  {
    title: 'Email Security Grader',
    description: 'Score de seguridad de email (0-100). Analizá SPF, DMARC y DKIM con grado A+ a F.',
    href: '/email-auth',
    icon: '📧',
  },
  {
    title: 'CIDR Calculator',
    description: 'Calculá red, broadcast, máscara, rango de hosts y cantidad de IPs utilizables.',
    href: '/cidr-calculator',
    icon: '🧮',
  },
  {
    title: 'IP Geolocation',
    description: 'Geolocalizá cualquier IP pública. Detectá tu IP automáticamente con mapa interactivo.',
    href: '/ip-geolocation',
    icon: '🌐',
  },
  {
    title: 'Security Headers',
    description: 'Verificá los 7 headers HTTP de seguridad de cualquier sitio. Score A+ a F.',
    href: '/security-headers',
    icon: '🛡️',
  },
  {
    title: 'Cert Monitor',
    description: 'Consultá certificados SSL/TLS emitidos para un dominio via Certificate Transparency.',
    href: '/cert-monitor',
    icon: '🔐',
  },
  {
    title: 'Site Report',
    description: 'Generá un reporte PDF completo de seguridad: email, headers, DNS y certificados.',
    href: '/site-report',
    icon: '📄',
  },
  {
    title: 'Blacklist Checker',
    description: 'Verificá si una IP o dominio está en 12 listas negras (DNSBL) en paralelo.',
    href: '/blacklist-checker',
    icon: '🚫',
  },
  {
    title: 'DNS Propagation',
    description: 'Consultá un dominio contra 8 resolvers DNS públicos y verificá si propagó correctamente.',
    href: '/dns-propagation',
    icon: '🌍',
  },
  {
    title: 'Cert Expiry',
    description: 'Verificá la expiración de certificados SSL/TLS de múltiples dominios a la vez.',
    href: '/cert-expiry',
    icon: '⏰',
  },
  {
    title: 'MX Analyzer',
    description: 'Analizá los registros MX de un dominio: proveedor, prioridades y redundancia.',
    href: '/mx-analyzer',
    icon: '📬',
  },
];
---

<BaseLayout
  title="Herramientas de Networking Gratuitas"
  description="Herramientas gratuitas de DNS, email, redes e IP para profesionales IT. Por delzo.cloud."
>
  <Header />
  <main id="main-content">
    <section class="hero">
      <div class="container">
        <p class="hero-eyebrow">delzo.cloud / tools</p>
        <h1>Herramientas de networking <span class="text-gradient">gratuitas</span></h1>
        <p class="hero-sub">DNS, email, seguridad, redes e IP — todo en un solo lugar. Sin registro, sin límites.</p>
        <div class="hero-count">{tools.length} herramientas disponibles</div>
      </div>
    </section>
    <section class="tools-section">
      <div class="container">
        <div class="tools-grid">
          {tools.map((tool, i) => (
            <div class:list={['tool-cell', { 'featured': i < 2 }]}>
              <ToolCard
                title={tool.title}
                description={tool.description}
                href={tool.href}
                icon={tool.icon}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hero {
    padding: 4.5rem 0 3.5rem;
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--verde);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
  }

  .hero h1 {
    font-size: 2.75rem;
    letter-spacing: -0.045em;
    margin-bottom: 0.85rem;
    line-height: 1.1;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--verde) 0%, #0D9468 50%, var(--turquesa) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--gris-medio);
    max-width: 460px;
    margin: 0 auto;
    line-height: 1.6;
    text-wrap: balance;
  }

  .hero-count {
    margin-top: 1.5rem;
    display: inline-block;
    padding: 0.3rem 0.85rem;
    background: var(--fondo-alt);
    border: 1px solid var(--borde);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--gris-medio);
    font-variant-numeric: tabular-nums;
  }

  .tools-section {
    padding: 0 0 5rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .tool-cell.featured :global(.tool-card) {
    padding: 2rem;
  }

  .tool-cell.featured :global(h3) {
    font-size: 1.15rem;
  }

  @media (min-width: 900px) {
    .tools-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .tool-cell.featured {
      grid-column: span 1;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: 3rem 0 2.5rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
