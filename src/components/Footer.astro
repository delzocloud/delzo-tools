---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="https://delzo.cloud" class="wordmark" target="_blank" rel="noopener">
        <span class="wordmark-delzo">delzo</span><span class="wordmark-cloud">.cloud</span>
      </a>
      <p>Herramientas de networking gratuitas para profesionales IT.</p>
    </div>
    <div class="footer-right">
      <nav class="footer-links">
        <a href="https://delzo.cloud" target="_blank" rel="noopener">Sitio principal</a>
        <a href="/privacidad">Privacidad</a>
        <a href="/terminos">Términos</a>
      </nav>
      <p class="footer-copy">&copy; {year} delzo.cloud</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 4rem;
    padding: 2rem 0;
    border-top: 1px solid var(--borde);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .wordmark {
    font-size: 1rem;
    text-decoration: none;
    letter-spacing: -0.03em;
  }

  .wordmark-delzo {
    font-weight: 700;
    color: var(--gris-oscuro);
  }

  .wordmark-cloud {
    font-weight: 400;
    color: var(--verde);
  }

  .footer-brand p {
    font-size: 0.82rem;
    color: var(--gris-claro);
    margin-top: 0.25rem;
  }

  .footer-right {
    text-align: right;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    font-size: 0.82rem;
    color: var(--gris-medio);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--verde-dark);
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--gris-claro);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: 1.25rem;
      text-align: center;
      align-items: center;
    }

    .footer-right {
      text-align: center;
    }

    .footer-links {
      justify-content: center;
    }
  }
</style>
