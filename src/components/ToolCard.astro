---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="tool-card card">
  <div class="tool-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</a>

<style>
  .tool-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    cursor: pointer;
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(110, 231, 183, 0.18));
    border-radius: 12px;
    font-size: 1.4rem;
  }

  h3 {
    font-size: 1.05rem;
    color: var(--gris-oscuro);
  }

  p {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--gris-medio);
  }
</style>
